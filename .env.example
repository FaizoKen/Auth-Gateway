DATABASE_URL=postgres://app:password@db:5432/auth_gateway
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
SESSION_SECRET=your_random_session_secret
BASE_URL=https://plugin-rolelogic.faizo.net
LISTEN_ADDR=0.0.0.0:8090
# Shared secret used by plugins to call /auth/internal/* endpoints.
# Generate with: openssl rand -hex 32
# Must match the INTERNAL_API_KEY set on every plugin that calls back into the gateway.
INTERNAL_API_KEY=your_random_internal_api_key
